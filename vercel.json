{
  "buildCommand": "pnpm --filter @workspace/miao-room run build",
  "outputDirectory": "artifacts/miao-room/dist/public",
  "installCommand": "pnpm install",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://random-ai-mail-ghost.vercel.app/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
