auto-install-peers=false
strict-peer-dependencies=false

# ============================================================================
# Vercel 部署排障（默认不启用，仅在 pnpm install 失败时临时打开）
# ============================================================================
#
# 若 Vercel 出现 peer dependency 缺失或包解析失败，可临时在 Vercel 环境变量
# 中设置以下值来覆盖，无需修改此文件：
#
#   PNPM_AUTO_INSTALL_PEERS=true     （自动安装 peer 依赖）
#   PNPM_SHAMEFULLY_HOIST=true       （提升所有依赖到根 node_modules）
#   PNPM_MINIMUM_RELEASE_AGE=0       （跳过 minimumReleaseAge 检查）
#
# 注意：以上仅作为排障手段，问题解决后应立即移除。
# ============================================================================

